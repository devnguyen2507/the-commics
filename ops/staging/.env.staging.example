# ======= DATABASE =======
DATABASE_URL=postgres://commics:YOUR_POSTGRES_PASSWORD_HERE@db:5432/commics_db
REDIS_URL=redis://default:YOUR_REDIS_PASSWORD_HERE@redis:6379/0

# ======= SECRETS =======
POSTGRES_USER=commics
POSTGRES_PASSWORD=YOUR_POSTGRES_PASSWORD_HERE
POSTGRES_DB=commics_db
REDIS_PASSWORD=YOUR_REDIS_PASSWORD_HERE

# ======= FRONTEND & SEO =======
SITE_URL=https://staging.commics.com # Đổi sang domain staging thật của bạn
PUBLIC_CDN_URL=https://images.komi.com # Hoặc domain ImgFlux
PUBLIC_HOME_COMICS_LIMIT=24
PUBLIC_PAGE_COMICS_LIMIT=24
PUBLIC_GRAPHQL_URL=https://staging.commics.com/api/
GRAPHQL_URL_INTERNAL=http://graphql:3001/

# ======= RUST CONFIG =======
ENVIRONMENT=staging # Dùng staging để trigger khóa config Introspection ở GraphQL
RUST_LOG=info,graphql=debug
MAX_QUERY_DEPTH=5
MAX_QUERY_COMPLEXITY=1500
