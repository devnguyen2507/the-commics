---
import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/ui/Breadcrumb.astro';
import { getCategories } from '../../lib/api/commics';
import { env } from '../../lib/config/env';
import { generateBreadcrumbSchema, generateCollectionSchema } from '../../lib/utils/schema';

let categories = [];
try {
  categories = await getCategories();
} catch (e) {
  console.error("Fetch error:", e);
}

const breadcrumbs = [{ label: 'Thể loại', url: `${Astro.url.origin}/the-loai` }];
const pageTitle = `Tổng Hợp Thể Loại Truyện Hentai, Manhwa | FanManga`;
const pageDesc = `🔥 Khám phá toàn bộ thể loại truyện hentai hot tại FanManga. Từ Nữ sinh, Loạn luân, hentai one-shot, series, tất cả đều hoàn toàn miễn phí.`;

const schemas = [
  generateCollectionSchema(pageTitle, pageDesc, `${Astro.url.origin}/the-loai`),
  generateBreadcrumbSchema([
    { label: 'Trang chủ', url: Astro.url.origin },
    { label: 'Thể loại', url: `${Astro.url.origin}/the-loai` }
  ])
];
---

<Layout title={pageTitle} description={pageDesc} schemas={schemas}>
  <div class="max-w-6xl mx-auto px-4 py-8 space-y-8">
    <Breadcrumb items={breadcrumbs} />
    
    <header class="border-l-4 border-blue-500 pl-4">
      <h1 class="text-3xl font-black uppercase tracking-tight">Tất cả Thể loại Truyện Tranh</h1>
    </header>
    
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-3">
      {categories.map((cat: any) => (
        <a href={`/the-loai/${cat.slug}/`} class="p-6 bg-zinc-900 border border-zinc-800 rounded-xl hover:bg-blue-600 hover:border-blue-500 transition-all text-center group">
          <span class="font-bold uppercase tracking-tight text-zinc-300 group-hover:text-white transition-colors">{cat.name}</span>
        </a>
      ))}
    </div>

    <!-- SEO Content Box -->
    <section class="max-w-6xl mx-auto px-0 pb-16 mt-16 pt-16 border-t border-zinc-800">
      <div class="bg-zinc-900/50 rounded-xl p-8 border border-zinc-800">
        <h2 class="text-3xl font-black text-white mb-6 uppercase tracking-tighter border-l-4 border-blue-600 pl-4">Khám phá thế giới truyện tranh đa dạng tại {env.SITE_NAME}</h2>
        
        <div class="prose prose-invert max-w-none text-zinc-400 text-sm leading-relaxed space-y-6">
          <p>
            Bạn đang phân vân không biết nên bắt đầu hành trình khám phá truyện tranh của mình từ đâu? Trang <strong>Tất cả Thể loại</strong> tại Fanmanga.net chính là bản đồ dẫn đường cho bạn. Chúng tôi tin rằng, mỗi người đều có một gu đọc truyện riêng, và với kho tàng thể loại phong phú này, chắc chắn bạn sẽ tìm thấy "chân ái" của mình.
          </p>

          <h2 class="text-xl font-bold text-zinc-200 mt-8 mb-4">Phân loại chi tiết - Tìm truyện dễ dàng</h2>
          <p>
            Tại Fanmanga.net, chúng tôi không chỉ liệt kê, mà còn phân loại cực kỳ khoa học để độc giả có thể tiếp cận bộ truyện mong muốn một cách nhanh nhất. Từ những thể loại kinh điển như Action, Adventure cho đến những xu hướng hiện đại như Isekai (Xuyên không), System (Hệ thống) hay những bộ truyện đậm chất Drama, mỗi chuyên mục đều được trau chuốt về mặt nội dung và số lượng.
          </p>
          <p>
            Đặc biệt, đối với những ai yêu thích sự trưởng thành và quyến rũ, chúng tôi cung cấp các phân mục Manhwa 18+, Hentai với nhiều tag con cực kỳ chi tiết như MILF, Nội y, Đồ bơi, hay Loạn luân. Mọi sở thích cá nhân, dù là kén người đọc nhất, đều được Fanmanga tôn trọng và phục vụ chu đáo.
          </p>

          <h2 class="text-xl font-bold text-zinc-200 mt-8 mb-4">Trải nghiệm đọc theo sở thích</h2>
          <p>
            Việc đọc truyện theo thể loại giúp bạn không bỏ lỡ những nét đặc trưng của từng phong cách nghệ thuật:
          </p>
          <ul class="list-disc pl-5 space-y-2">
            <li><strong>Manga (Nhật Bản):</strong> Những câu chuyện có chiều sâu, đa dạng đề tài từ học đường đến siêu nhiên.</li>
            <li><strong>Manhwa (Hàn Quốc):</strong> Nổi bật với nét vẽ hiện đại, màu sắc sống động (Webtoon) và những câu chuyện về trả thù, quyền lực.</li>
            <li><strong>Manhua (Trung Quốc):</strong> Thế giới tu tiên huyền ảo, những cuộc phiêu lưu đầy màu sắc của các võ hiệp.</li>
            <li><strong>One-shot:</strong> Phù hợp cho những ai muốn đọc nhanh, gọn và trọn vẹn trong một chương duy nhất.</li>
          </ul>

          <h2 class="text-xl font-bold text-zinc-200 mt-8 mb-4">Fanmanga.net - Chất lượng làm nên thương hiệu</h2>
          <p>
            Mọi thể loại tại website đều được đảm bảo về tốc độ tải trang và chất lượng hình ảnh HD tốt nhất. Chúng tôi liên tục cập nhật bộ lọc để độc giả có thể tìm kiếm theo trạng thái (đang tiến hành/hoàn tất), theo lượt xem hoặc theo đánh giá của cộng đồng. Điều này giúp bạn luôn chọn được những bộ truyện chất lượng nhất để thưởng thức.
          </p>

          <h3 class="text-lg font-bold text-zinc-200 mt-6 mb-3">Giao diện thân thiện và thông minh</h3>
          <p>
            Trang thể loại được thiết kế tối giản nhưng tinh tế, giúp bạn dễ dàng thao tác trên mọi thiết bị. Dù bạn đang sử dụng iPhone, Android hay máy tính bảng, việc lướt qua hàng chục thể loại để tìm ra câu chuyện ưng ý là vô cùng mượt mà.
          </p>

          <h3 class="text-lg font-bold text-zinc-200 mt-6 mb-3">Sứ mệnh của Fanmanga</h3>
          <p>
            Chúng tôi mong muốn xây dựng một thư viện truyện tranh số 1 Việt Nam, nơi mọi độc giả đều tìm thấy niềm vui và sự thư giãn. Niềm đam mê của bạn chính là động lực lớn nhất để Fanmanga.net không ngừng nâng cấp và phát triển.
          </p>

          <p class="font-bold text-zinc-300">
            Khám phá ngay danh sách các thể loại cực hot và bắt đầu hành trình kì diệu của bạn tại Fanmanga.net. Nếu có bất kỳ đề xuất thêm thể loại mới, hãy liên hệ chúng tôi qua: <strong>info@fanmanga.net</strong>.
          </p>

          <div class="mt-8 pt-8 border-t border-zinc-800">
            <p class="text-xs italic text-zinc-500">
              Keywords: thể loại truyện tranh, đọc truyện manga theo thể loại, manhwa 18+ các loại, danh sách hentai tag, fanmanga.net thể loại hay, tìm truyện theo sở thích.
            </p>
          </div>
        </div>
      </div>
    </section>
  </div>
</Layout>
