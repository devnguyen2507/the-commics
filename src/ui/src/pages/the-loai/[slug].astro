---
import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/ui/Breadcrumb.astro';
import ComicCard from '../../components/ui/ComicCard.astro';
import Pagination from '../../components/ui/Pagination.astro';
import { getComics, getCategories, getComicsCount } from '../../lib/api/commics';
import { env } from '../../lib/config/env';
import { generateBreadcrumbSchema, generateCollectionSchema } from '../../lib/utils/schema';
import { GENRE_SEO_DATA } from '../../lib/constants/seoData';

const { slug } = Astro.params;

export const prerender = process.env.OUTPUT_MODE === 'static';

export async function getStaticPaths() {
  const { getCategories } = await import('../../lib/api/commics');
  const categories = await getCategories();
  return categories.map(cat => ({
    params: { slug: cat.slug },
  }));
}

const pageStr = Astro.url.searchParams.get('page');
const page = pageStr ? parseInt(pageStr, 10) : 1;
const limit = env.PUBLIC_PAGE_COMICS_LIMIT;
const offset = (page - 1) * limit;

let comics = [];
let totalPages = 0;
let category: any = null;
let targetCategoryName = 'Thể loại';
let categoryDescription: string | null = null;

try {
  const [categories, categoryComics, countData] = await Promise.all([
    getCategories(),
    getComics({ filter: { categorySlug: slug }, first: limit, after: offset.toString() }),
    getComicsCount({ filter: { categorySlug: slug } })
  ]);
  comics = categoryComics;
  totalPages = Math.ceil(countData / limit);
  category = categories.find((c: any) => c.slug === slug);
  if (category) {
    targetCategoryName = category.name;
    // description từ DB (Phase 2: sau khi migration + GraphQL expose)
    categoryDescription = (category as any).description ?? null;
  } else {
    // Nếu không tìm thấy category => 404
    return Astro.redirect('/404');
  }
} catch (e) {
  console.error('Fetch error:', e);
}

const genreSeo = GENRE_SEO_DATA[slug as string];

const baseTitle = page > 1 
  ? `Truyện ${targetCategoryName} Hay Nhất - Trang ${page} | ${env.SITE_NAME}` 
  : `Truyện ${targetCategoryName} Hay Nhất | ${env.SITE_NAME}`;

const pageTitle = genreSeo?.title && page === 1 ? genreSeo.title : baseTitle;

const h3Match = categoryDescription ? categoryDescription.match(/<h3>(.*?)<\/h3>/i) : null;
const extractedDesc = h3Match ? h3Match[1].replace(/<[^>]*>?/gm, '') : null;

const baseDesc = extractedDesc 
  ? `${extractedDesc} Đọc truyện ${targetCategoryName} chất lượng cao tại ${env.SITE_NAME}.`
  : `Đọc truyện tranh ${targetCategoryName} hay nhất. Trọn bộ vietsub mới nhất, cập nhật liên tục 24/7 hoàn toàn miễn phí tại ${env.SITE_NAME}.`;

const pageDesc = genreSeo?.description && page === 1 ? genreSeo.description : baseDesc;

const breadcrumbs = [
  { label: 'Thể loại', url: `${Astro.url.origin}/the-loai` },
  { label: targetCategoryName, url: `${Astro.url.origin}/the-loai/${slug}` }
];

const schemas = [
  generateCollectionSchema(pageTitle, pageDesc, `${Astro.url.origin}/the-loai/${slug}`),
  generateBreadcrumbSchema([
    { label: 'Trang chủ', url: Astro.url.origin },
    ...breadcrumbs
  ])
];
---

<Layout 
  title={pageTitle} 
  description={pageDesc} 
  schemas={schemas}
  robots={(!category || page > 1) ? "noindex, follow" : undefined}
>
  <div class="max-w-6xl mx-auto px-4 py-8 space-y-8">
    <Breadcrumb items={breadcrumbs} />

    <header class="border-l-4 border-blue-500 pl-4">
      <h1 class="text-3xl font-black uppercase tracking-tight">Truyện Tranh {targetCategoryName}</h1>
    </header>

    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-x-4 gap-y-8 animate-slide-up">
      {comics.map((comic) => (
        <ComicCard comic={comic} />
      ))}
    </div>

    {comics.length > 0 && <Pagination currentPage={page} totalPages={totalPages} baseUrl={`/the-loai/${slug}`} />}

    {comics.length === 0 && (
      <div class="py-20 text-center text-zinc-500 font-bold uppercase tracking-widest italic">
        Chưa có truyện nào trong thể loại này
      </div>
    )}

    <!-- SEO Content Box — hiển thị description từ DB nếu có -->
    <section class="pb-16">
      <div class="bg-zinc-900/50 rounded-xl p-8 border border-zinc-800">
        <h2 class="text-xl font-bold text-zinc-300 mb-4 tracking-tighter uppercase">Tuyển Tập Truyện Tranh {targetCategoryName} Hot Nhất Tại {env.SITE_NAME}</h2>
        <div class="bg-zinc-950/40 p-4 rounded-xl border border-zinc-800/50 shadow-inner">
          <div class="text-zinc-400 text-sm leading-relaxed max-h-[250px] overflow-y-auto custom-scrollbar pr-2 space-y-3">
            {categoryDescription ? (
              <div set:html={categoryDescription} />
            ) : (
              <>
                <p>
                  <strong>Thể loại {targetCategoryName}</strong> là tập hợp các bộ truyện tranh mang phong cách và nội dung đặc trưng của thể loại này.
                  Tại {env.SITE_NAME}, bạn có thể đọc hàng trăm bộ {targetCategoryName} vietsub chất lượng cao, cập nhật mỗi ngày.
                </p>
                <p>
                  Tất cả truyện được đọc miễn phí, không cần đăng ký tài khoản.
                </p>
              </>
            )}
          </div>
        </div>
      </div>
    </section>
  </div>
</Layout>
