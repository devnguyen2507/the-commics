---
import Layout from '../layouts/Layout.astro';
import ComicCard from '../components/ui/ComicCard.astro';
import { getComics } from '../lib/api/commics';
import { ComicSort } from '../lib/api/commics/generated';

let hotComics = [];
try {
  hotComics = await getComics({ first: 24, sort: ComicSort.MostViewed });
} catch (e) {
  console.error("Fetch error:", e);
}

const title = "Truyện Hot - Đọc nhiều nhất - Commics";
const description = "Top truyện tranh hot nhất, được xem nhiều nhất tuần qua. Cập nhật liên tục những siêu phẩm manga, manhwa, manhua hấp dẫn.";
---

<Layout title={title} description={description}>
  <main class="max-w-6xl mx-auto px-4 py-8">
    <div class="flex items-center justify-between mb-8">
      <h1 class="text-3xl font-black text-white uppercase tracking-tighter border-l-4 border-blue-600 pl-4">
        Truyện Hot <span class="text-blue-500">Nhất</span>
      </h1>
    </div>

    {hotComics.length > 0 ? (
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-x-4 gap-y-8 animate-slide-up">
        {hotComics.map((comic) => (
          <ComicCard comic={comic} />
        ))}
      </div>
    ) : (
      <div class="py-20 text-center">
        <p class="text-zinc-500 font-bold uppercase tracking-widest">Đang cập nhật danh sách truyện hot...</p>
      </div>
    )}
    )}
  </main>
</Layout>
