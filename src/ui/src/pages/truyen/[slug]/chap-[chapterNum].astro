---
import Layout from '../../../layouts/Layout.astro';
import ReaderNavbar from '../../../components/feature/reader/ReaderNavbar.astro';
import { ReaderImage } from '../../../components/feature/reader/ReaderImage';
import { getComic, getChapter } from '../../../lib/api/commics';
import { getImageUrl } from '../../../lib/utils/image';
import { env } from '../../../lib/config/env';
import { slugify } from '../../../lib/utils/slug';

const { slug, chapterNum } = Astro.params;

export const prerender = process.env.OUTPUT_MODE === 'static';

export async function getStaticPaths() {
  const { getComics } = await import('../../../lib/api/commics');
  const comics = await getComics({ first: 1000 }); // Increase limit for full static build
  return comics.flatMap(comic => 
    comic.chapters.map(ch => ({
      params: { slug: comic.slug, chapterNum: slugify(ch.chapterNumber?.toString() || '') },
    }))
  );
}

let comic;
try {
  comic = await getComic(slug!);
} catch (e) {
  console.error("Fetch comic error:", e);
  return Astro.redirect('/404');
}

const chapterMeta = comic?.chapters.find((c: any) => slugify(c.chapterNumber) === chapterNum);
if (!chapterMeta) {
  return Astro.redirect('/404');
}

let chapter;
try {
  chapter = await getChapter(chapterMeta.id);
} catch (e) {
  console.error("Fetch chapter error:", e);
  return Astro.redirect('/404');
}

if (!chapter) {
  return Astro.redirect('/404');
}

const comicTitle = chapter.comic?.title || comic?.title || "Truyện";

const getChapterNum = (id?: string | null) => {
  if (!id) return null;
  return comic?.chapters.find((c: any) => c.id === id)?.chapterNumber;
}

const nextChapNum = slugify(getChapterNum(chapter.nextChapterId) || '');
const prevChapNum = slugify(getChapterNum(chapter.prevChapterId) || '');

const pageUrl = `${env.SITE_URL.replace(/\/$/, '')}/truyen/${slug}/chap-${slugify(chapter.chapterNumber)}`;
const firstPageImage = chapter.images?.[0]?.url ? getImageUrl(chapter.images[0].url) : '';
const descriptionText = chapter.description || `Đọc ngay ${comicTitle} Chương ${chapter.chapterNumber} online chất lượng cao, cập nhật nhanh nhất tại ${env.SITE_NAME}. Không quảng cáo làm phiền.`;
const pageTitle = `Đọc Chương ${chapter.chapterNumber} - ${comicTitle} - ${env.SITE_NAME}`;

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": `${comicTitle} - Chương ${chapter.chapterNumber}`,
    "description": descriptionText,
    "url": pageUrl,
    "image": firstPageImage,
    "isPartOf": {
      "@type": "ComicSeries",
      "name": comicTitle,
      "url": `${env.SITE_URL.replace(/\/$/, '')}/truyen/${slug}`
    },
    "inLanguage": "vi"
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Trang chủ", "item": env.SITE_URL.replace(/\/$/, '') },
      { "@type": "ListItem", "position": 2, "name": comicTitle, "item": `${env.SITE_URL.replace(/\/$/, '')}/truyen/${slug}` },
      { "@type": "ListItem", "position": 3, "name": `Chương ${chapter.chapterNumber}`, "item": pageUrl }
    ]
  }
];
---

<Layout title={pageTitle} description={descriptionText}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>
  <div class="max-w-4xl mx-auto flex flex-col pt-4 pb-32 min-h-screen bg-black">
    {chapter.images.map((img: any, index: number) => (
      <ReaderImage 
        client:visible
        src={getImageUrl(img.url)}
        alt={`${comicTitle} - Chương ${chapter.chapterNumber} - Trang ${index + 1}`}
        aspectRatio={`${img.w}/${img.h}`}
        page={index + 1}
      />
    ))}
    
    <div class="py-20 flex flex-col items-center gap-6">
       <p class="text-zinc-500 text-sm font-bold uppercase tracking-widest">Bạn đã đọc hết chương này</p>
       <div class="flex gap-4">
         {nextChapNum && (
           <a 
             href={`/truyen/${slug}/chap-${nextChapNum}`} 
             data-astro-prefetch="load"
             class="px-12 py-4 bg-blue-600 hover:bg-blue-500 text-white font-black rounded-xl transition-all uppercase tracking-tighter"
           >
             Tiếp theo
           </a>
         )}
         <a href={`/truyen/${slug}`} class="px-8 py-4 bg-zinc-800 hover:bg-zinc-700 text-white font-black rounded-xl transition-all uppercase tracking-tighter">
           Quay lại
         </a>
       </div>
    </div>

    <!-- SEO Content Box -->
    <section class="w-full px-4 pb-16">
        <div class="bg-zinc-900/50 rounded-xl p-8 border border-zinc-800">
            <h2 class="text-xl font-bold text-zinc-300 mb-4 uppercase tracking-tighter">{comicTitle} - Chương {chapter.chapterNumber}</h2>
            <div class="bg-zinc-950/40 p-4 rounded-xl border border-zinc-800/50 shadow-inner">
                <div class="text-zinc-400 text-sm leading-relaxed max-h-[250px] overflow-y-auto custom-scrollbar pr-2 space-y-3">
                    {chapter.description ? (
                        <div set:html={chapter.description} />
                    ) : (
                        <p>{}</p>
                    )}
                </div>
            </div>
        </div>
    </section>
  </div>

  <ReaderNavbar 
    comicTitle={comicTitle}
    chapterNumber={chapter.chapterNumber}
    comicSlug={slug!}
    nextChapterUrl={nextChapNum ? `/truyen/${slug}/chap-${nextChapNum}` : undefined}
    prevChapterUrl={prevChapNum ? `/truyen/${slug}/chap-${prevChapNum}` : undefined}
  />
</Layout>

<div 
  id="reader-data" 
  data-comic-id={chapter.comic?.id} 
  data-comic-slug={slug} 
  data-comic-title={comicTitle} 
  data-chapter-id={chapterMeta.id} 
  data-chapter-number={chapter.chapterNumber}
></div>

<script>
  import { storage } from '../../../lib/utils/storage';
  
  const dataset = document.getElementById('reader-data')?.dataset;
  if (dataset) {
    storage.addHistory({
      id: dataset.comicId!,
      slug: dataset.comicSlug!,
      title: dataset.comicTitle!,
      coverImage: "", // We could pass this too if needed
      chapterId: dataset.chapterId,
      chapterNumber: dataset.chapterNumber
    });
  }
</script>

<style>
  .no-scrollbar::-webkit-scrollbar {
    display: none;
  }
  .no-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>
