---
import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/ui/Breadcrumb.astro';
import { BookmarkButton } from '../../components/ui/BookmarkButton';
import { getComic, getComics } from '../../lib/api/commics';
import { getImageUrl } from '../../lib/utils/image';
import { env } from '../../lib/config/env';
import sanitizeHtml from 'sanitize-html';
import { slugify } from '../../lib/utils/slug';
import { generateBreadcrumbSchema, generateComicSchema } from '../../lib/utils/schema';

const { slug } = Astro.params;

export const prerender = process.env.OUTPUT_MODE === 'static';

export async function getStaticPaths() {
  const { getComics } = await import('../../lib/api/commics');
  const { env } = await import('../../lib/config/env');
  const comics = await getComics({ first: env.STATIC_BUILD_LIMIT }); // Use static build limit
  return comics.map(comic => ({
    params: { slug: comic.slug },
  }));
}

let comic;
try {
  comic = await getComic(slug!);
} catch (e) {
  console.error("Fetch error:", e);
  // Fallback / 404
  return Astro.redirect('/404');
}

if (!comic) {
  return Astro.redirect('/404');
}

let relatedComics = [];
try {
  if (comic.categories && comic.categories.length > 0) {
    const primaryCat = comic.categories[0];
    const related = await getComics({
      first: env.PUBLIC_HOME_COMICS_LIMIT + 1,
      filter: { categorySlug: primaryCat.slug }
    });
    // Filter out current comic and take exactly env.PUBLIC_HOME_COMICS_LIMIT
    relatedComics = related
      .filter(c => c.id !== comic.id)
      .slice(0, env.PUBLIC_HOME_COMICS_LIMIT);
  }
} catch (e) {
  console.error("Fetch related error:", e);
}

const breadcrumbs = [
  { label: comic.categories?.[0]?.name || 'Truyện', url: `${Astro.url.origin}/the-loai/${comic.categories?.[0]?.slug || ''}` },
  { label: comic.title, url: `${Astro.url.origin}/truyen/${comic.slug}` }
];

const pageTitle = `Đọc Truyện ${comic.title} | ${env.SITE_NAME}`;
const plainComicDesc = comic.description ? comic.description.replace(/<[^>]+>/g, '').trim() : '';
const pageDesc = plainComicDesc
  ? (plainComicDesc.length > 150 ? plainComicDesc.substring(0, 140) + '...' : plainComicDesc)
  : '';

const sanitizedDescription = sanitizeHtml(comic.description || "Chưa có mô tả cho bộ truyện này.", {
  allowedTags: ['p', 'b', 'i', 'strong', 'em', 'br', 'h2', 'h3', 'ul', 'ol', 'li'],
  allowedAttributes: {}
});

const schemas = [
  generateComicSchema(comic, Astro.url.origin, env.SITE_NAME || 'Commics'),
  generateBreadcrumbSchema([
    { label: 'Trang chủ', url: Astro.url.origin },
    ...breadcrumbs
  ])
];
---

<Layout title={pageTitle} description={pageDesc} ogType="book" image={comic.coverImage} schemas={schemas}>
  <div class="max-w-6xl mx-auto px-4 py-8 space-y-8">
    <Breadcrumb items={breadcrumbs} />
    
    <section class="flex flex-col md:flex-row gap-8">
      <div class="w-full md:w-64 shrink-0">
        <div class="aspect-[3/4] rounded-xl overflow-hidden shadow-2xl border border-zinc-800 bg-zinc-900">
          <img src={comic.coverImage} alt={comic.title} class="w-full h-full object-cover" />
        </div>
      </div>
      
      <div class="flex-grow space-y-6">
        <div class="space-y-2">
          <h1 class="text-3xl md:text-4xl font-black uppercase tracking-tighter leading-none">{comic.title}</h1>
          <p class="text-zinc-500 font-medium">Tác giả: <span class="text-zinc-300">{comic.author}</span></p>
        </div>
        
        <div class="flex flex-wrap gap-2">
          {comic.categories?.map((cat: any) => (
            <a href={`/the-loai/${cat.slug}/`} class="px-3 py-1 bg-zinc-900 hover:bg-blue-600 border border-zinc-800 rounded-full text-xs font-bold uppercase tracking-tight transition-colors">
              {cat.name}
            </a>
          ))}
        </div>
        
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 p-4 bg-zinc-900/50 rounded-xl border border-zinc-800">
           <div class="text-center">
             <div class="text-zinc-500 text-[10px] uppercase font-bold">Rating</div>
             <div class="text-yellow-500 font-black">{comic.ratingScore.toFixed(1)}</div>
           </div>
           <div class="text-center border-l border-zinc-800">
             <div class="text-zinc-500 text-[10px] uppercase font-bold">Views</div>
             <div class="font-black">{comic.viewCount.toLocaleString()}</div>
           </div>
           <div class="text-center border-l border-zinc-800">
             <div class="text-zinc-500 text-[10px] uppercase font-bold">Status</div>
             <div class="text-blue-500 font-black uppercase text-xs">{comic.status}</div>
           </div>
           <div class="text-center border-l border-zinc-800">
             <div class="text-zinc-500 text-[10px] uppercase font-bold">Chapters</div>
             <div class="font-black text-xs">{comic.chapters?.length || 0}</div>
           </div>
        </div>
        
        <div class="space-y-4">
          <h2 class="text-xs font-black uppercase tracking-widest text-zinc-500 border-b border-zinc-800 pb-2">Tóm tắt nội dung truyện {comic.title}</h2>
          <div class="bg-zinc-900/40 p-4 rounded-xl border border-zinc-800/50 shadow-inner">
            <div 
              class="text-zinc-400 text-sm leading-relaxed max-h-[250px] overflow-y-auto custom-scrollbar pr-2"
              set:html={sanitizedDescription}
            />
          </div>
        </div>
        
        <div class="flex gap-4">
          <a href={`/truyen/${comic.slug}/chap-${slugify(comic.chapters?.[0]?.chapterNumber || '1')}/`} class="px-8 py-3 bg-blue-600 hover:bg-blue-500 text-white font-black rounded-lg transition-all uppercase text-sm tracking-wide">
            Đọc từ đầu
          </a>
          <BookmarkButton client:load comic={comic} />
        </div>
      </div>
    </section>
    
    <section class="space-y-4">
       <header class="flex items-center justify-between border-l-4 border-blue-500 pl-4">
         <h2 class="text-xl font-black uppercase tracking-tight">Danh sách các chương mới nhất của {comic.title}</h2>
         <span class="text-[10px] font-bold text-zinc-500 uppercase">Mới nhất: {comic.chapters?.[comic.chapters.length - 1]?.chapterNumber || 'N/A'}</span>
       </header>
       
        <div class="grid grid-cols-1 md:grid-cols-2 gap-2">
          {comic.chapters?.slice().reverse().map((ch: any) => (
            <a href={`/truyen/${comic.slug}/chap-${slugify(ch.chapterNumber)}/`} class="flex items-center justify-between p-4 bg-zinc-900/30 hover:bg-zinc-800 border border-zinc-800/50 rounded-lg group transition-colors">
              <span class="font-bold text-sm text-zinc-300 group-hover:text-blue-500 transition-colors">Chương {ch.chapterNumber}</span>
              <span class="text-[10px] text-zinc-600 uppercase font-medium">Ch.{ch.orderIndex}</span>
            </a>
          ))}
        </div>
    </section>

    {relatedComics.length > 0 && (
      <section class="space-y-4">
        <header class="flex items-center justify-between border-l-4 border-blue-500 pl-4">
          <h2 class="text-xl font-black uppercase tracking-tight">Các bộ truyện {comic.categories?.[0]?.name} tương tự {comic.title}</h2>
        </header>
        <div class="grid grid-cols-2 sm:grid-cols-3 gap-4">
          {relatedComics.map((c: any) => (
            <a href={`/truyen/${c.slug}/`} class="group space-y-2 block">
              <div class="aspect-[3/4] overflow-hidden rounded-xl bg-zinc-900">
                <img 
                  src={getImageUrl(c.coverImage)} 
                  alt={c.title}
                  class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
                  loading="lazy"
                />
              </div>
              <h3 class="font-medium text-sm line-clamp-2 leading-snug group-hover:text-blue-500 transition-colors">
                {c.title}
              </h3>
            </a>
          ))}
        </div>
      </section>
    )}

  </div>
</Layout>
