---
import Layout from '../layouts/Layout.astro';
import { env } from '../lib/config/env';

const title = `Câu hỏi thường gặp - FAQ - ${env.SITE_NAME}`;
const description = `Tổng hợp các câu hỏi và giải đáp thắc mắc thường gặp khi sử dụng ${env.SITE_NAME}.`;

const faqs = [
  {
    question: `${env.SITE_NAME} có miễn phí không?`,
    answer: `Có, ${env.SITE_NAME} hoàn toàn miễn phí. Bạn có thể đọc tất cả truyện mà không cần đăng ký tài khoản hay trả phí.`
  },
  {
    question: 'Làm sao để tìm truyện theo thể loại?',
    answer: 'Truy cập trang Thể loại (/the-loai) để xem danh sách tất cả thể loại. Nhấp vào thể loại muốn đọc để xem danh sách truyện tương ứng.'
  },
  {
    question: `Lịch cập nhật chương mới trên ${env.SITE_NAME} như thế nào?`,
    answer: `${env.SITE_NAME} cập nhật truyện mới hàng ngày. Truy cập trang Truyện Mới (/truyen-moi) để xem những bộ vừa được cập nhật chapter mới nhất.`
  },
  {
    question: 'Tôi có thể đọc truyện trên điện thoại không?',
    answer: `Có, ${env.SITE_NAME} được tối ưu cho cả điện thoại và máy tính. Giao diện tự động điều chỉnh theo kích thước màn hình.`
  },
  {
    question: 'Lịch sử đọc truyện được lưu ở đâu?',
    answer: 'Lịch sử đọc được lưu trực tiếp trên trình duyệt của bạn (localStorage). Xóa cache trình duyệt sẽ xóa lịch sử đọc.'
  },
  {
    question: 'Tôi muốn báo cáo truyện vi phạm bản quyền?',
    answer: 'Vui lòng liên hệ qua trang Liên hệ (/lien-he) kèm theo tên bộ truyện và thông tin bản quyền. Chúng tôi sẽ xử lý trong 72 giờ.'
  },
  {
    question: 'Tại sao truyện bị lỗi hình ảnh?',
    answer: 'Hình ảnh có thể tải chậm do kết nối mạng. Thử làm mới trang (F5) hoặc xóa cache trình duyệt. Nếu vẫn lỗi, báo cho chúng tôi qua trang Liên hệ.'
  },
  {
    question: `${env.SITE_NAME} có ứng dụng di động không?`,
    answer: `Hiện tại ${env.SITE_NAME} chưa có ứng dụng riêng. Bạn có thể sử dụng trực tiếp qua trình duyệt di động với trải nghiệm tương đương ứng dụng.`
  }
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(({ question, answer }) => ({
    '@type': 'Question',
    name: question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: answer,
    },
  })),
};
---

<Layout title={title} description={description}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <main class="max-w-3xl mx-auto px-4 py-12">
    <h1 class="text-3xl font-black text-white uppercase tracking-tighter border-l-4 border-blue-600 pl-4 mb-8">
      Câu hỏi Thường Gặp
    </h1>

    <div class="space-y-4">
      {faqs.map(({ question, answer }, i) => (
        <details class="group bg-zinc-900/50 border border-zinc-800 rounded-xl overflow-hidden">
          <summary class="flex items-center justify-between p-5 cursor-pointer list-none font-bold text-zinc-200 hover:text-white transition-colors">
            <h2 class="text-base font-bold m-0 p-0 inline-block">{question}</h2>
            <svg class="w-4 h-4 shrink-0 text-zinc-500 group-open:rotate-180 transition-transform" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <div class="px-5 pb-5 text-sm text-zinc-400 leading-relaxed border-t border-zinc-800/50 pt-4">
            {answer}
          </div>
        </details>
      ))}
    </div>

    <div class="mt-12 p-6 bg-zinc-900/30 rounded-xl border border-zinc-800 text-center">
      <p class="text-zinc-500 text-sm">Không tìm thấy câu trả lời?</p>
      <a href="/lien-he/" class="mt-2 inline-block px-6 py-2 bg-blue-600 hover:bg-blue-500 text-white text-sm font-bold rounded-lg transition-colors">
        Liên hệ với chúng tôi
      </a>
    </div>
  </main>
</Layout>
