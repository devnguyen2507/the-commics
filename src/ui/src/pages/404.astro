---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 - Không tìm thấy trang - Commics" description="Trang bạn đang tìm kiếm không tồn tại hoặc đã bị xóa.">
  <div class="h-[60vh] flex flex-col items-center justify-center text-center space-y-6 px-4">
    <h1 class="text-8xl font-black text-white px-8 py-2 border-y-4 border-blue-600">404</h1>
    <div class="space-y-2">
      <h2 class="text-2xl font-bold text-zinc-300">Không tìm thấy trang</h2>
      <p class="text-zinc-500">Trang bạn đang tìm kiếm có thể đã bị xóa, đổi tên hoặc tạm thời không thể truy cập.</p>
    </div>
    <a href="/" class="mt-8 px-8 py-3 bg-blue-600 hover:bg-blue-500 text-white font-black rounded-lg transition-all uppercase text-sm tracking-wide">
      Về Trang Chủ
    </a>
  </div>
</Layout>
