---
import Layout from '../layouts/Layout.astro';
import HeroSlider from '../components/feature/home/HeroSlider.astro';
import ComicCard from '../components/ui/ComicCard.astro';
import { getComics } from '../lib/api/commics';
import { env } from '../lib/config/env';
import { generateWebsiteSchema } from '../lib/utils/schema';

export const prerender = process.env.OUTPUT_MODE === 'static';

let latestComics = [];
try {
  latestComics = await getComics({ first: env.PUBLIC_HOME_COMICS_LIMIT });
} catch (e) {
  console.error("Fetch error:", e);
	// Mock fallback for development if API is down
	latestComics = Array(12).fill(null).map((_, i) => ({
		id: `mock-${i}`,
		slug: `truyen-mau-${i}`,
		title: `Truyện comic mẫu số ${i + 1}`,
		coverImage: `https://picsum.photos/seed/${i}/300/400`,
		ratingScore: 4.5,
		viewCount: 12500,
		status: "Đang tiến hành",
		author: "Tác giả mẫu"
	}));
}

const pageTitle = `${env.SITE_NAME} - Đọc truyện tranh online`;
const siteUrl = Astro.url.origin;
const schemas = [generateWebsiteSchema(env.SITE_NAME || 'Commics', siteUrl)];

---

<Layout title={pageTitle} isHome={true} ogType="website" schemas={schemas}>
	<HeroSlider comics={latestComics} />
	
	<div class="max-w-6xl mx-auto px-4 py-12 space-y-8">
		<header class="flex items-center justify-between border-l-4 border-blue-500 pl-4">
			<h2 class="text-2xl font-black uppercase tracking-tight">Mới cập nhật</h2>
			<a href="/the-loai/" class="text-xs font-bold text-zinc-500 hover:text-blue-500 uppercase tracking-widest transition-colors">
				Xem tất cả →
			</a>
		</header>
		
		<div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-x-4 gap-y-8">
			{latestComics.map((comic) => (
				<ComicCard comic={comic} />
			))}
		</div>
	</div>
	
	<!-- SEO Box -->
	<section class="max-w-6xl mx-auto px-4 pb-16">
		<div class="bg-zinc-900/50 rounded-xl p-8 border border-zinc-800">
			<h1 class="text-3xl font-black text-white mb-6 uppercase tracking-tighter border-l-4 border-blue-600 pl-4">{env.SITE_NAME} Đọc truyện tranh online miễn phí</h1>
			
			<div class="prose prose-invert max-w-none text-zinc-400 text-sm leading-relaxed space-y-6">
				<p>
					Chào mừng bạn đến với <strong>Fanmanga.net</strong>, điểm đến lý tưởng cho những tín đồ đam mê truyện tranh tại Việt Nam. Với sứ mệnh mang đến không gian giải trí đỉnh cao, chúng tôi tự hào là nền tảng cung cấp kho tàng truyện tranh khổng lồ, đa dạng thể loại và hoàn toàn miễn phí. Dù bạn là fan của Manga truyền thống, Manhwa hiện đại hay Manhua kịch tính, {env.SITE_NAME} luôn sẵn sàng đáp ứng mọi nhu cầu của bạn.
				</p>

				<h2 class="text-xl font-bold text-zinc-200 mt-8 mb-4">Tại sao nên chọn đọc truyện tại Fanmanga.net?</h2>
				<p>
					Trong bối cảnh các website truyện tranh mọc lên như nấm, Fanmanga.net vẫn giữ vững vị thế nhờ vào sự chỉn chu trong từng khung hình và tốc độ cập nhật thần tốc. Chúng tôi hiểu rằng, đối với một "mọt truyện", cảm giác được đọc chương mới nhất ngay khi vừa ra mắt là điều tuyệt vời nhất. Chính vì thế, đội ngũ của chúng tôi làm việc không ngừng nghỉ để đảm bảo mọi bộ truyện hot nhất đều có mặt trên hệ thống sớm nhất có thể.
				</p>
				<p>
					Không chỉ có tốc độ, chất lượng hình ảnh cũng là yếu tố chúng tôi đặt lên hàng đầu. Mọi trang truyện đều được xử lý ở độ phân giải cao, sắc nét, không bị mờ nhòe, giúp bạn tận hưởng trọn vẹn nét vẽ của các họa sĩ tài năng. Đặc biệt, giao diện của Fanmanga được tối ưu hóa cực tốt cho cả điện thoại di động và máy tính, mang lại trải nghiệm đọc mượt mà, không giật lag.
				</p>

				<h2 class="text-xl font-bold text-zinc-200 mt-8 mb-4">Khám phá kho truyện tranh đa dạng thể loại</h2>
				<p>
					Tại Fanmanga.net, bạn sẽ lạc vào thế giới của hàng nghìn bộ truyện trải dài qua nhiều phân khúc khác nhau:
				</p>
				<ul class="list-disc pl-5 space-y-2">
					<li><strong>Action (Hành động):</strong> Những trận chiến nảy lửa, kịch tính và đầy nghẹt thở.</li>
					<li><strong>Adventure (Phiêu lưu):</strong> Cùng nhân vật khám phá những vùng đất mới lạ và những bí ẩn chưa có lời giải.</li>
					<li><strong>Comedy (Hài hước):</strong> Những tràng cười sảng khoái giúp bạn giải tỏa căng thẳng sau giờ làm việc.</li>
					<li><strong>Romance (Lãng mạn):</strong> Những câu chuyện tình yêu ngọt ngào, cảm động và đầy chiều sâu.</li>
					<li><strong>Horror (Kinh dị):</strong> Thử thách lòng dũng cảm với những bộ truyện ma mị và đầy ám ảnh.</li>
					<li><strong>18+ (Người lớn):</strong> Những bộ Manhwa, Hentai dành riêng cho khán giả trưởng thành với nội dung mặn mà và art style cực phẩm.</li>
				</ul>

				<h2 class="text-xl font-bold text-zinc-200 mt-8 mb-4">Trải nghiệm đọc truyện đỉnh cao trên mọi thiết bị</h2>
				<p>
					Thấu hiểu thói quen của người dùng hiện đại, Fanmanga.net được thiết kế theo phong cách responsive hiện đại. Bạn có thể dễ dàng theo dõi bộ truyện yêu thích trên chiếc smartphone của mình khi đang di chuyển trên xe bus, hoặc tận hưởng màn hình rộng của máy tính khi ở nhà. Hệ thống tự động lưu lại lịch sử đọc truyện, giúp bạn có thể tiếp tục hành trình của mình ở bất cứ đâu mà không cần tốn công tìm lại chương đang đọc dở.
				</p>

				<h3 class="text-lg font-bold text-zinc-200 mt-6 mb-3">Tính năng tìm kiếm thông minh</h3>
				<p>
					Với bộ lọc nâng cao, bạn có thể dễ dàng tìm kiếm truyện theo tên tác giả, tên bộ truyện, hoặc theo từng tag thể loại cụ thể. Nếu bạn đang cảm thấy phân vân không biết nên đọc gì tiếp theo, chuyên mục "Truyện Hot" và "Truyện Mới Cập Nhật" sẽ là những gợi ý tuyệt vời dành cho bạn.
				</p>

				<h3 class="text-lg font-bold text-zinc-200 mt-6 mb-3">Cộng đồng Fanmanga - Nơi kết nối niềm đam mê</h3>
				<p>
					Fanmanga không chỉ là một website, đó là một cộng đồng. Tại đây, bạn có thể tự do thảo luận, chia sẻ cảm nghĩ về các tình tiết trong truyện. Chúng tôi luôn lắng nghe ý kiến đóng góp của độc giả để ngày càng hoàn thiện dịch vụ, mang tới một sân chơi văn minh và sôi động cho tất cả mọi người.
				</p>

				<h2 class="text-xl font-bold text-zinc-200 mt-8 mb-4">Cam kết của chúng tôi</h2>
				<p>
					Chúng tôi cam kết bảo mật thông tin người dùng và luôn nỗ lực loại bỏ các quảng cáo gây khó chịu để bạn có thể tập trung hoàn toàn vào nội dung truyện. Fanmanga.net hướng tới việc xây dựng một thư viện số bền vững, nơi lưu giữ những giá trị nghệ thuật của thế giới truyện tranh.
				</p>
				<p>
					Nếu bạn có bất kỳ thắc mắc hoặc cần hỗ trợ, đừng ngần ngại liên hệ với chúng tôi qua email: <strong>info@fanmanga.net</strong>. Chúng tôi luôn sẵn lòng lắng nghe và hỗ trợ bạn 24/7.
				</p>

				<div class="mt-8 pt-8 border-t border-zinc-800">
					<p class="text-xs italic text-zinc-500">
						Từ khóa tìm kiếm: đọc truyện tranh, manga online, manhwa 18+, đọc truyện miễn phí, fanmanga, fanmanga.net, truyện hot, truyện mới.
					</p>
				</div>
			</div>
		</div>
	</section>
</Layout>
