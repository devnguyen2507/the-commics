---
import Layout from '../layouts/Layout.astro';
import ComicCard from '../components/ui/ComicCard.astro';
import Pagination from '../components/ui/Pagination.astro';
import { getComics, getComicsCount } from '../lib/api/commics';
import { ComicSort } from '../lib/api/commics/generated';
import { env } from '../lib/config/env';

const pageStr = Astro.url.searchParams.get('page');
const page = pageStr ? parseInt(pageStr, 10) : 1;
const limit = env.PUBLIC_PAGE_COMICS_LIMIT;
const offset = (page - 1) * limit;

let truyenNganComics = [];
let totalPages = 0;

try {
  const [comicsData, countData] = await Promise.all([
    getComics({ 
      first: limit, 
      after: offset.toString(), 
      sort: ComicSort.Latest,
      filter: { categorySlug: 'truyen-ngan' }
    }),
    getComicsCount({ filter: { categorySlug: 'truyen-ngan' } })
  ]);
  truyenNganComics = comicsData;
  totalPages = Math.ceil(countData / limit);
} catch (e) {
  console.error("Fetch error:", e);
}

const title = page > 1 ? `Truyện Ngắn - Trang ${page} - ${env.SITE_NAME}` : `Truyện Ngắn - ${env.SITE_NAME}`;
const description = `Danh sách truyện ngắn hay nhất, cập nhật liên tục các oneshot, truyện ngắn trọn bộ tại ${env.SITE_NAME}.`;
---

<Layout title={title} description={description}>
  <Fragment slot="head">
    {page > 1 && <meta name="robots" content="noindex, follow" />}
  </Fragment>
  <main class="max-w-6xl mx-auto px-4 py-8">
    <div class="flex items-center justify-between mb-8">
      <h1 class="text-3xl font-black text-white uppercase tracking-tighter border-l-4 border-blue-600 pl-4">
        Truyện Ngắn <span class="text-blue-500">Hay</span>
      </h1>
    </div>

    {truyenNganComics.length > 0 ? (
      <>
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-x-4 gap-y-8 animate-slide-up">
          {truyenNganComics.map((comic) => (
            <ComicCard comic={comic} />
          ))}
        </div>
        <Pagination currentPage={page} totalPages={totalPages} baseUrl="/truyen-ngan" />
      </>
    ) : (
      <div class="py-20 text-center">
        <p class="text-zinc-500 font-bold uppercase tracking-widest">Không có truyện ngắn nào...</p>
      </div>
    )}

    <!-- SEO Content Box -->
    <section class="mt-16 pb-16">
      <div class="bg-zinc-900/50 rounded-xl p-8 border border-zinc-800">
        <h2 class="text-xl font-bold text-zinc-300 mb-4">Truyện Ngắn (Oneshot)</h2>
        <div class="text-zinc-500 text-sm leading-relaxed space-y-4">
          <p>
            <strong>Truyện ngắn</strong> hay còn gọi là oneshot, là những câu chuyện được kể và trọn vẹn trong một khoảng thời gian ngắn, thường chỉ có 1 đến vài chapter.
          </p>
          <p>
            Rất phù hợp để đọc giải trí nhanh trong giờ giải lao!
          </p>
        </div>
      </div>
    </section>
  </main>
</Layout>
