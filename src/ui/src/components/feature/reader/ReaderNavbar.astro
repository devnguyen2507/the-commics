---
interface Props {
  comicTitle: string;
  chapterNumber: string;
  comicSlug: string;
  nextChapterId?: string | null;
  prevChapterId?: string | null;
  nextChapterUrl?: string | null;
  prevChapterUrl?: string | null;
}

const { comicTitle, chapterNumber, comicSlug, nextChapterId, prevChapterId, nextChapterUrl, prevChapterUrl } = Astro.props;
---

<nav id="reader-navbar" class="fixed bottom-6 left-1/2 -translate-x-1/2 z-50 transition-transform duration-300">
  <div class="bg-zinc-900/80 backdrop-blur-md border border-zinc-700/50 rounded-full px-6 py-3 flex items-center gap-4 shadow-2xl">
    <a href={`/truyen/${comicSlug}/`} class="text-zinc-400 hover:text-white transition-colors" title="Back to Detail">
      <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
    </a>
    
    <div class="h-4 w-[1px] bg-zinc-700"></div>
    
    <div class="flex flex-col items-center min-w-[120px]">
      <span class="text-[10px] text-zinc-500 font-bold uppercase tracking-tight truncate max-w-[150px]">{comicTitle}</span>
      <span class="text-xs font-black text-blue-500 uppercase tracking-tighter">Chương {chapterNumber}</span>
    </div>

    <div class="h-4 w-[1px] bg-zinc-700"></div>

    <div class="flex items-center gap-2">
      {prevChapterUrl || prevChapterId ? (
        <a href={prevChapterUrl || `/truyen/${comicSlug}/${prevChapterId}`} class="p-2 bg-zinc-800 hover:bg-blue-600 rounded-full text-white transition-colors" title="Previous Chapter">
           <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
        </a>
      ) : (
        <div class="p-2 bg-zinc-800/30 rounded-full text-zinc-600 cursor-not-allowed">
           <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
        </div>
      )}

      {nextChapterUrl || nextChapterId ? (
        <a href={nextChapterUrl || `/truyen/${comicSlug}/${nextChapterId}`} class="p-2 bg-zinc-800 hover:bg-blue-600 rounded-full text-white transition-colors" title="Next Chapter">
           <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
        </a>
      ) : (
        <div class="p-2 bg-zinc-800/30 rounded-full text-zinc-600 cursor-not-allowed">
           <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
        </div>
      )}
    </div>
  </div>
</nav>

<script>
  let lastScrollY = window.scrollY;
  const navbar = document.getElementById('reader-navbar');

  window.addEventListener('scroll', () => {
    if (window.scrollY > lastScrollY && window.scrollY > 200) {
      navbar?.classList.add('translate-y-32');
    } else {
      navbar?.classList.remove('translate-y-32');
    }
    lastScrollY = window.scrollY;
  }, { passive: true });
</script>
