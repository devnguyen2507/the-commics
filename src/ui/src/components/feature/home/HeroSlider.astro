---
import type { ComicView } from '../../../lib/api/commics/adapters/comic';

interface Props {
  comics: ComicView[];
}

const { comics } = Astro.props;
const featured = comics.slice(0, 3);
---

<section class="relative w-full aspect-[21/9] md:aspect-[3/1] bg-zinc-900 overflow-hidden">
  {featured.length > 0 ? (
    <div class="absolute inset-0">
      <img 
        src={featured[0].coverImage} 
        alt={featured[0].title}
        class="w-full h-full object-cover opacity-40 blur-sm scale-105"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-black via-black/20 to-transparent"></div>
      
      <div class="absolute bottom-0 left-0 w-full p-6 md:p-12 max-w-6xl mx-auto flex flex-col md:flex-row items-end md:items-center gap-6">
        <div class="hidden md:block w-48 aspect-[3/4] rounded-lg overflow-hidden shadow-2xl border border-white/10 shrink-0">
           <img src={featured[0].coverImage} alt={featured[0].title} class="w-full h-full object-cover" />
        </div>
        
        <div class="space-y-4 text-left">
          <div class="inline-block px-3 py-1 bg-blue-600 text-[10px] font-bold uppercase rounded-sm">Trending Now</div>
          <h2 class="text-3xl md:text-5xl font-black text-white leading-tight uppercase tracking-tighter">
            {featured[0].title}
          </h2>
          <div class="flex items-center gap-4 text-sm text-zinc-300">
             <span>{featured[0].author}</span>
             <span class="w-1 h-1 bg-zinc-500 rounded-full"></span>
             <span class="text-yellow-500 font-bold">{featured[0].ratingScore.toFixed(1)} Rating</span>
          </div>
          <p class="text-zinc-400 max-w-2xl line-clamp-2 text-sm md:text-base">
            {featured[0].description || "Đọc ngay bộ truyện hot nhất hiện nay tại Commics."}
          </p>
          <div class="pt-2">
            <a href={`/${featured[0].slug}`} class="inline-flex items-center justify-center px-8 py-3 bg-white text-black font-bold rounded-full hover:bg-blue-500 hover:text-white transition-all uppercase text-sm tracking-wide">
              Đọc ngay
            </a>
          </div>
        </div>
      </div>
    </div>
  ) : (
    <div class="flex items-center justify-center h-full text-zinc-700 font-bold uppercase tracking-widest italic">
      Commics Featured
    </div>
  )}
</section>
