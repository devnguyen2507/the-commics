---
interface Props {
  currentPage: number;
  totalPages: number;
  baseUrl: string; // e.g. "/truyen-moi" or "/tim-kiem?q=abc"
}

const { currentPage, totalPages, baseUrl } = Astro.props;

if (totalPages <= 1) return null;

const createUrl = (page: number) => {
  const isQuery = baseUrl.includes('?');
  const sep = isQuery ? '&' : '?';
  return `${baseUrl}${sep}page=${page}`;
};

const MAX_PAGES_TO_SHOW = 5;
let startPage = Math.max(1, currentPage - Math.floor(MAX_PAGES_TO_SHOW / 2));
let endPage = startPage + MAX_PAGES_TO_SHOW - 1;

if (endPage > totalPages) {
  endPage = totalPages;
  startPage = Math.max(1, endPage - MAX_PAGES_TO_SHOW + 1);
}

const pages = Array.from({ length: endPage - startPage + 1 }, (_, i) => startPage + i);
---

<nav class="flex items-center justify-center gap-2 mt-12 mb-8 aria-label='Pagination'">
  {currentPage > 1 ? (
    <a href={createUrl(currentPage - 1)} class="px-4 py-2 bg-zinc-900 border border-zinc-800 text-zinc-300 rounded hover:bg-zinc-800 hover:text-white transition-colors" aria-label="Previous page">
      &laquo; Trước
    </a>
  ) : (
    <span class="px-4 py-2 bg-zinc-900/50 border border-zinc-800/50 text-zinc-600 rounded cursor-not-allowed">
      &laquo; Trước
    </span>
  )}

  {startPage > 1 && (
    <>
      <a href={createUrl(1)} class="w-10 h-10 flex items-center justify-center bg-zinc-900 border border-zinc-800 text-zinc-300 rounded hover:bg-zinc-800 hover:text-white transition-colors">1</a>
      {startPage > 2 && <span class="text-zinc-600 px-1">...</span>}
    </>
  )}

  {pages.map((p) => (
    <a 
      href={createUrl(p)} 
      class={`w-10 h-10 flex items-center justify-center border rounded transition-colors ${
        p === currentPage 
          ? 'bg-blue-600 border-blue-500 text-white font-bold' 
          : 'bg-zinc-900 border-zinc-800 text-zinc-300 hover:bg-zinc-800 hover:text-white'
      }`}
      aria-current={p === currentPage ? 'page' : undefined}
    >
      {p}
    </a>
  ))}

  {endPage < totalPages && (
    <>
      {endPage < totalPages - 1 && <span class="text-zinc-600 px-1">...</span>}
      <a href={createUrl(totalPages)} class="w-10 h-10 flex items-center justify-center bg-zinc-900 border border-zinc-800 text-zinc-300 rounded hover:bg-zinc-800 hover:text-white transition-colors">{totalPages}</a>
    </>
  )}

  {currentPage < totalPages ? (
    <a href={createUrl(currentPage + 1)} class="px-4 py-2 bg-zinc-900 border border-zinc-800 text-zinc-300 rounded hover:bg-zinc-800 hover:text-white transition-colors" aria-label="Next page">
      Sau &raquo;
    </a>
  ) : (
    <span class="px-4 py-2 bg-zinc-900/50 border border-zinc-800/50 text-zinc-600 rounded cursor-not-allowed">
      Sau &raquo;
    </span>
  )}
</nav>
