---
import { env } from '../../lib/config/env';

interface Props {
  title?: string;
  description?: string;
}

const { title = env.SITE_NAME, description = `Đọc truyện tranh online miễn phí, cập nhật mới nhất tại ${env.SITE_NAME}.` } = Astro.props;
---

<footer class="bg-zinc-900 border-t border-zinc-800 py-12 mt-auto">
  <div class="max-w-6xl mx-auto px-4">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div class="space-y-4">
        <h2 class="text-xl font-bold text-blue-500 uppercase tracking-tighter">{title}</h2>
        <p class="text-zinc-400 text-sm">{description}</p>
      </div>

      <div>
        <h3 class="text-white font-semibold mb-4">Khám phá</h3>
        <ul class="space-y-2 text-zinc-400 text-sm">
          <li><a href="/" class="hover:text-white transition-colors">Trang chủ</a></li>
          <li><a href="/truyen-moi" class="hover:text-white transition-colors">Truyện Mới</a></li>
          <li><a href="/truyen-hot" class="hover:text-white transition-colors">Truyện Hot</a></li>
          <li><a href="/truyen-ngan" class="hover:text-white transition-colors">Truyện Ngắn</a></li>
          <li><a href="/the-loai" class="hover:text-white transition-colors">Thể loại</a></li>
          <li><a href="/tim-kiem" class="hover:text-white transition-colors">Tìm kiếm</a></li>
        </ul>
      </div>

      <div>
        <h3 class="text-white font-semibold mb-4">Thông tin</h3>
        <ul class="space-y-2 text-zinc-400 text-sm">
          <li><a href="/cau-hoi-thuong-gap" class="hover:text-white transition-colors">Câu hỏi thường gặp</a></li>
          <li><a href="/lien-he" class="hover:text-white transition-colors">Liên hệ</a></li>
          <li><a href="/dieu-khoan" class="hover:text-white transition-colors">Điều khoản sử dụng</a></li>
          <li><a href="/chinh-sach" class="hover:text-white transition-colors">Chính sách bảo mật</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-12 pt-8 border-t border-zinc-800 text-center text-zinc-500 text-xs">
      &copy; 2026 {title}. All rights reserved.
    </div>
  </div>
</footer>
