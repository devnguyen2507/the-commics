---
interface Props {
  title?: string;
  description?: string;
}

const { title = "COMMICS", description = "Đọc truyện tranh hentai online hay nhất." } = Astro.props;
---

<footer class="bg-zinc-900 border-t border-zinc-800 py-12 mt-auto">
  <div class="max-w-6xl mx-auto px-4">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div class="space-y-4">
        <h2 class="text-xl font-bold text-blue-500">{title}</h2>
        <p class="text-zinc-400 text-sm">{description}</p>
      </div>
      
      <div>
        <h3 class="text-white font-semibold mb-4">Điều hướng</h3>
        <ul class="space-y-2 text-zinc-400 text-sm">
          <li><a href="/" class="hover:text-white transition-colors">Trang chủ</a></li>
          <li><a href="/the-loai" class="hover:text-white transition-colors">Thể loại</a></li>
          <li><a href="/truyen-hot" class="hover:text-white transition-colors">Truyện Hot</a></li>
        </ul>
      </div>

      <div>
        <h3 class="text-white font-semibold mb-4">Thông tin</h3>
        <ul class="space-y-2 text-zinc-400 text-sm">
          <li><a href="#" class="hover:text-white transition-colors">Giới thiệu</a></li>
          <li><a href="#" class="hover:text-white transition-colors">Liên hệ</a></li>
          <li><a href="#" class="hover:text-white transition-colors">DMCA</a></li>
        </ul>
      </div>
    </div>
    
    <div class="mt-12 pt-8 border-t border-zinc-800 text-center text-zinc-500 text-xs">
      &copy; 2026 {title}. All rights reserved.
    </div>
  </div>
</footer>
